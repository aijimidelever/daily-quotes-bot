[
  {
    "id": 1,
    "text": "凡杀不死我的，必将使我更强大。",
    "source": "《偶像的黄昏》",
    "author": "弗里德里希·尼采",
    "theme": "courage-growth",
    "tags": ["坚韧", "成长", "逆境"]
  },
  {
    "id": 2,
    "text": "生活中只有一种英雄主义，那就是在认清生活真相之后依然热爱生活。",
    "source": "《名人传》",
    "author": "罗曼·罗兰",
    "theme": "courage-growth",
    "tags": ["英雄主义", "勇气", "热爱"]
  },
  {
    "id": 3,
    "text": "纵有疾风起，人生不言弃。",
    "source": "《起风了》",
    "author": "堀辰雄",
    "theme": "courage-growth",
    "tags": ["坚韧", "人生", "希望"]
  },
  {
    "id": 4,
    "text": "一个人可以被毁灭，但不能被打败。",
    "source": "《老人与海》",
    "author": "欧内斯特·海明威",
    "theme": "courage-growth",
    "tags": ["坚韧", "尊严", "勇气"]
  },
  {
    "id": 5,
    "text": "勇气是压力之下的优雅。",
    "source": "《丧钟为谁而鸣》",
    "author": "欧内斯特·海明威",
    "theme": "courage-growth",
    "tags": ["勇气", "压力", "优雅"]
  },
  {
    "id": 6,
    "text": "当你穿过暴风雨，你就不再是原来那个人。",
    "source": "《海边的卡夫卡》",
    "author": "村上春树",
    "theme": "courage-growth",
    "tags": ["成长", "历练", "蜕变"]
  },
  {
    "id": 7,
    "text": "不必太纠结于当下，也不必太忧虑未来，当你经历过一些事情的时候，眼前的风景已经和从前不一样了。",
    "source": "《挪威的森林》",
    "author": "村上春树",
    "theme": "courage-growth",
    "tags": ["成长", "释怀", "人生"]
  },
  {
    "id": 8,
    "text": "世界以痛吻我，要我报之以歌。",
    "source": "《飞鸟集》",
    "author": "泰戈尔",
    "theme": "courage-growth",
    "tags": ["豁达", "勇气", "乐观"]
  },
  {
    "id": 9,
    "text": "信念是鸟，它在黎明前的黑暗中能感觉到光明，并开始歌唱。",
    "source": "《飞鸟集》",
    "author": "泰戈尔",
    "theme": "courage-growth",
    "tags": ["信念", "希望", "黑暗"]
  },
  {
    "id": 10,
    "text": "那是最美好的时代，那是最糟糕的时代。",
    "source": "《双城记》",
    "author": "查尔斯·狄更斯",
    "theme": "courage-growth",
    "tags": ["时代", "辩证", "人生"]
  },
  {
    "id": 11,
    "text": "勇气不是拥有力量去继续，而是在你疲惫不堪时仍然选择继续。",
    "source": "《漫长的中场休息》",
    "author": "本·方登",
    "theme": "courage-growth",
    "tags": ["勇气", "坚持", "疲惫"]
  },
  {
    "id": 12,
    "text": "人可以被习惯所塑造，但也可以被勇气所重塑。",
    "source": "《习惯的力量》",
    "author": "查尔斯·都希格",
    "theme": "courage-growth",
    "tags": ["习惯", "勇气", "改变"]
  },
  {
    "id": 13,
    "text": "在最深的绝望里，遇见最美丽的风景。",
    "source": "《我的灵魂骑在纸背上》",
    "author": "三毛",
    "theme": "courage-growth",
    "tags": ["绝望", "希望", "成长"]
  },
  {
    "id": 14,
    "text": "万物皆有裂痕，那是光照进来的地方。",
    "source": "《颂歌》",
    "author": "莱昂纳德·科恩",
    "theme": "courage-growth",
    "tags": ["缺陷", "希望", "接纳"]
  },
  {
    "id": 15,
    "text": "人的一切痛苦，本质上都是对自己无能的愤怒。",
    "source": "《狂人日记》",
    "author": "王小波",
    "theme": "courage-growth",
    "tags": ["痛苦", "自省", "成长"]
  },
  {
    "id": 16,
    "text": "真正的强者，不是没有眼泪的人，而是含着眼泪奔跑的人。",
    "source": "《人生》演讲",
    "author": "董卿",
    "theme": "courage-growth",
    "tags": ["强者", "眼泪", "坚韧"]
  },
  {
    "id": 17,
    "text": "勇敢是：当你还未开始就已知道自己会输，可你依然要去做，而且无论如何都要把它坚持到底。",
    "source": "《杀死一只知更鸟》",
    "author": "哈珀·李",
    "theme": "courage-growth",
    "tags": ["勇敢", "坚持", "信念"]
  },
  {
    "id": 18,
    "text": "人生有两个悲剧：一个是没有得到你心爱的东西，另一个是得到了你心爱的东西。",
    "source": "《自深深处》",
    "author": "奥斯卡·王尔德",
    "theme": "courage-growth",
    "tags": ["人生", "欲望", "哲思"]
  },
  {
    "id": 19,
    "text": "勇敢的人不是不害怕，而是害怕之后仍然选择面对。",
    "source": "《追风筝的人》",
    "author": "卡勒德·胡赛尼",
    "theme": "courage-growth",
    "tags": ["勇敢", "恐惧", "面对"]
  },
  {
    "id": 20,
    "text": "20岁后的每一个决定，都是一场自我重塑。",
    "source": "《你当像鸟飞往你的山》",
    "author": "塔拉·韦斯特弗",
    "theme": "courage-growth",
    "tags": ["成长", "选择", "重塑"]
  },
  {
    "id": 21,
    "text": "我们终此一生，就是要摆脱他人的期待，找到真正的自己。",
    "source": "《无声告白》",
    "author": "伍绮诗",
    "theme": "courage-growth",
    "tags": ["自我", "期待", "觉醒"]
  },
  {
    "id": 22,
    "text": "如果你因失去了太阳而流泪，那么你也将失去群星了。",
    "source": "《飞鸟集》",
    "author": "泰戈尔",
    "theme": "courage-growth",
    "tags": ["失去", "珍惜", "释怀"]
  },
  {
    "id": 23,
    "text": "世上只有一种真正的英雄主义，那就是在认清生活的真相后，依然选择热爱它。",
    "source": "《米开朗琪罗传》",
    "author": "罗曼·罗兰",
    "theme": "courage-growth",
    "tags": ["英雄主义", "热爱", "勇气"]
  },
  {
    "id": 24,
    "text": "在隆冬，我终于知道，我身上有一个不可战胜的夏天。",
    "source": "《反与正》",
    "author": "阿尔贝·加缪",
    "theme": "courage-growth",
    "tags": ["坚韧", "希望", "内在"]
  },
  {
    "id": 25,
    "text": "人最宝贵的是生命，生命对每个人只有一次。人的一生应当这样度过：当他回首往事时，不会因虚度年华而悔恨，也不会因碌碌无为而羞愧。",
    "source": "《钢铁是怎样炼成的》",
    "author": "奥斯特洛夫斯基",
    "theme": "courage-growth",
    "tags": ["生命", "奋斗", "无悔"]
  },
  {
    "id": 26,
    "text": "生活不能等待别人来安排，要自己去争取和奋斗。",
    "source": "《平凡的世界》",
    "author": "路遥",
    "theme": "courage-growth",
    "tags": ["奋斗", "主动", "人生"]
  },
  {
    "id": 27,
    "text": "无论风暴将我带到什么样的岸边，我都将以主人的身份上岸。",
    "source": "《沉思录》",
    "author": "马可·奥勒留",
    "theme": "courage-growth",
    "tags": ["命运", "自主", "勇气"]
  },
  {
    "id": 28,
    "text": "成长是一笔交易，我们都是用朴素的童真与未经人事的洁白交换长大的勇气。",
    "source": "《小王子》解读",
    "author": "宫崎骏",
    "theme": "courage-growth",
    "tags": ["成长", "童真", "代价"]
  },
  {
    "id": 29,
    "text": "不要因为走得太远，忘了我们为什么出发。",
    "source": "《先知》",
    "author": "纪伯伦",
    "theme": "courage-growth",
    "tags": ["初心", "方向", "反思"]
  },
  {
    "id": 30,
    "text": "世界上只有一种失败，就是半途而废。",
    "source": "《人性的弱点》",
    "author": "戴尔·卡耐基",
    "theme": "courage-growth",
    "tags": ["坚持", "失败", "毅力"]
  },
  {
    "id": 31,
    "text": "没有绝望的处境，只有对处境绝望的人。",
    "source": "《火种》",
    "author": "徐向前",
    "theme": "courage-growth",
    "tags": ["绝望", "心态", "希望"]
  },
  {
    "id": 32,
    "text": "成长不是变得世故，而是在复杂中守住天真。",
    "source": "《目送》",
    "author": "龙应台",
    "theme": "courage-growth",
    "tags": ["成长", "天真", "世故"]
  },
  {
    "id": 33,
    "text": "所谓无底深渊，下去，也是前程万里。",
    "source": "《素履之往》",
    "author": "木心",
    "theme": "courage-growth",
    "tags": ["绝境", "希望", "勇气"]
  },
  {
    "id": 34,
    "text": "往前走，别回头。那里虽有你的记忆，但前方才有你的命运。",
    "source": "《俄狄浦斯王》",
    "author": "索福克勒斯",
    "theme": "courage-growth",
    "tags": ["前行", "命运", "勇气"]
  },
  {
    "id": 35,
    "text": "希望是美好的，也许是人间至善，而美好的事物永不消逝。",
    "source": "《肖申克的救赎》",
    "author": "斯蒂芬·金",
    "theme": "courage-growth",
    "tags": ["希望", "美好", "信念"]
  },
  {
    "id": 36,
    "text": "战胜恐惧的唯一方法就是面对它。",
    "source": "《沙丘》",
    "author": "弗兰克·赫伯特",
    "theme": "courage-growth",
    "tags": ["恐惧", "面对", "勇气"]
  },
  {
    "id": 37,
    "text": "即使世界变得黑暗，也要做自己的光。",
    "source": "《老人与海》解读",
    "author": "欧内斯特·海明威",
    "theme": "courage-growth",
    "tags": ["自愈", "光明", "独立"]
  },
  {
    "id": 38,
    "text": "每个优秀的人，都有一段沉默的时光。那段时光，是付出了很多努力却得不到结果的日子，我们把它叫做扎根。",
    "source": "《习近平用典》引述",
    "author": "佚名",
    "theme": "courage-growth",
    "tags": ["沉默", "坚持", "扎根"]
  },
  {
    "id": 39,
    "text": "一个人知道自己为什么而活，就可以忍受任何一种生活。",
    "source": "《查拉图斯特拉如是说》",
    "author": "弗里德里希·尼采",
    "theme": "courage-growth",
    "tags": ["意义", "忍受", "信念"]
  },
  {
    "id": 40,
    "text": "我们一路奋战，不是为了改变世界，而是为了不让世界改变我们。",
    "source": "《熔炉》",
    "author": "孔枝泳",
    "theme": "courage-growth",
    "tags": ["坚守", "初心", "抗争"]
  }
]
