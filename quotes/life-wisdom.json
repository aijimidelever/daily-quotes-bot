[
  {
    "id": 1,
    "text": "人生如逆旅，我亦是行人。",
    "source": "《临江仙·送钱穆父》",
    "author": "苏轼",
    "theme": "life-wisdom",
    "tags": ["人生", "豁达", "旅行"]
  },
  {
    "id": 2,
    "text": "道可道，非常道；名可名，非常名。",
    "source": "《道德经》",
    "author": "老子",
    "theme": "life-wisdom",
    "tags": ["哲理", "大道", "思辨"]
  },
  {
    "id": 3,
    "text": "上善若水。水善利万物而不争。",
    "source": "《道德经》",
    "author": "老子",
    "theme": "life-wisdom",
    "tags": ["处世", "不争", "柔韧"]
  },
  {
    "id": 4,
    "text": "知人者智，自知者明。胜人者有力，自胜者强。",
    "source": "《道德经》",
    "author": "老子",
    "theme": "life-wisdom",
    "tags": ["自知", "自省", "强大"]
  },
  {
    "id": 5,
    "text": "天地有大美而不言，四时有明法而不议，万物有成理而不说。",
    "source": "《庄子·知北游》",
    "author": "庄子",
    "theme": "life-wisdom",
    "tags": ["自然", "天道", "静观"]
  },
  {
    "id": 6,
    "text": "独与天地精神往来。",
    "source": "《庄子·天下》",
    "author": "庄子",
    "theme": "life-wisdom",
    "tags": ["自由", "独立", "超脱"]
  },
  {
    "id": 7,
    "text": "吾生也有涯，而知也无涯。",
    "source": "《庄子·养生主》",
    "author": "庄子",
    "theme": "life-wisdom",
    "tags": ["求知", "有限", "谦卑"]
  },
  {
    "id": 8,
    "text": "不戚戚于贫贱，不汲汲于富贵。",
    "source": "《五柳先生传》",
    "author": "陶渊明",
    "theme": "life-wisdom",
    "tags": ["淡泊", "安贫", "志趣"]
  },
  {
    "id": 9,
    "text": "采菊东篱下，悠然见南山。",
    "source": "《饮酒·其五》",
    "author": "陶渊明",
    "theme": "life-wisdom",
    "tags": ["闲适", "田园", "自在"]
  },
  {
    "id": 10,
    "text": "行到水穷处，坐看云起时。",
    "source": "《终南别业》",
    "author": "王维",
    "theme": "life-wisdom",
    "tags": ["禅意", "从容", "随缘"]
  },
  {
    "id": 11,
    "text": "人生得意须尽欢，莫使金樽空对月。",
    "source": "《将进酒》",
    "author": "李白",
    "theme": "life-wisdom",
    "tags": ["洒脱", "及时", "豪放"]
  },
  {
    "id": 12,
    "text": "此中有真意，欲辨已忘言。",
    "source": "《饮酒·其五》",
    "author": "陶渊明",
    "theme": "life-wisdom",
    "tags": ["真意", "无言", "意境"]
  },
  {
    "id": 13,
    "text": "不以物喜，不以己悲。",
    "source": "《岳阳楼记》",
    "author": "范仲淹",
    "theme": "life-wisdom",
    "tags": ["淡定", "胸怀", "豁达"]
  },
  {
    "id": 14,
    "text": "人有悲欢离合，月有阴晴圆缺，此事古难全。",
    "source": "《水调歌头·明月几时有》",
    "author": "苏轼",
    "theme": "life-wisdom",
    "tags": ["人生", "无常", "接受"]
  },
  {
    "id": 15,
    "text": "竹杖芒鞋轻胜马，谁怕？一蓑烟雨任平生。",
    "source": "《定风波·莫听穿林打叶声》",
    "author": "苏轼",
    "theme": "life-wisdom",
    "tags": ["旷达", "无畏", "风雨"]
  },
  {
    "id": 16,
    "text": "幸福就是身体无痛苦，灵魂无烦恼。",
    "source": "《幸福之路》",
    "author": "罗素",
    "theme": "life-wisdom",
    "tags": ["幸福", "健康", "安宁"]
  },
  {
    "id": 17,
    "text": "人的真正的幸福，并不在于得到快乐，而在于避开痛苦。",
    "source": "《幸福之路》",
    "author": "罗素",
    "theme": "life-wisdom",
    "tags": ["幸福", "智慧", "取舍"]
  },
  {
    "id": 18,
    "text": "一个明智地追求幸福的人，除了其生活赖以建立的主要兴趣之外，还应设法培养一些业余的兴趣。",
    "source": "《幸福之路》",
    "author": "罗素",
    "theme": "life-wisdom",
    "tags": ["兴趣", "生活", "平衡"]
  },
  {
    "id": 19,
    "text": "我到树林中去，因为我希望从容地生活，只面对生活的基本事实。",
    "source": "《瓦尔登湖》",
    "author": "梭罗",
    "theme": "life-wisdom",
    "tags": ["简朴", "自然", "本真"]
  },
  {
    "id": 20,
    "text": "大多数人都生活在平静的绝望中。",
    "source": "《瓦尔登湖》",
    "author": "梭罗",
    "theme": "life-wisdom",
    "tags": ["警醒", "人生", "反思"]
  },
  {
    "id": 21,
    "text": "一个人怎样看待自己，决定了此人的命运，指向了他的归宿。",
    "source": "《论自助》",
    "author": "爱默生",
    "theme": "life-wisdom",
    "tags": ["自信", "命运", "认知"]
  },
  {
    "id": 22,
    "text": "相信你自己的思想，相信你内心深处认为对你适用的东西对一切人都适用。",
    "source": "《论自助》",
    "author": "爱默生",
    "theme": "life-wisdom",
    "tags": ["自信", "独立", "思想"]
  },
  {
    "id": 23,
    "text": "世界上最伟大的事，是一个人懂得如何做自己的主人。",
    "source": "《随笔集》",
    "author": "蒙田",
    "theme": "life-wisdom",
    "tags": ["自律", "自主", "修为"]
  },
  {
    "id": 24,
    "text": "生命本没有意义，你要能给它什么意义，它就有什么意义。",
    "source": "《人生不过如此》",
    "author": "林语堂",
    "theme": "life-wisdom",
    "tags": ["人生", "意义", "创造"]
  },
  {
    "id": 25,
    "text": "一个真正的旅行家必是一个流浪者，经历流浪者的快乐、诱惑和探险意念。",
    "source": "《生活的艺术》",
    "author": "林语堂",
    "theme": "life-wisdom",
    "tags": ["旅行", "自由", "探索"]
  },
  {
    "id": 26,
    "text": "享受悠闲的生活只要一种艺术家的性情，在一种全然悠闲的情绪中，去消遣一个闲暇无事的下午。",
    "source": "《生活的艺术》",
    "author": "林语堂",
    "theme": "life-wisdom",
    "tags": ["悠闲", "享受", "艺术"]
  },
  {
    "id": 27,
    "text": "外在的眼睛看见现象，内在的眼睛看到本质。",
    "source": "《安静》",
    "author": "周国平",
    "theme": "life-wisdom",
    "tags": ["洞察", "内在", "本质"]
  },
  {
    "id": 28,
    "text": "人生最好的境界是丰富的安静。",
    "source": "《安静》",
    "author": "周国平",
    "theme": "life-wisdom",
    "tags": ["安静", "丰富", "境界"]
  },
  {
    "id": 29,
    "text": "世上有味之事，包括诗、酒、哲学、爱情，往往无用。吟无用之诗，醉无用之酒，读无用之书，钟无用之情，终于成一无用之人，却因此活得有滋有味。",
    "source": "《安静》",
    "author": "周国平",
    "theme": "life-wisdom",
    "tags": ["无用", "趣味", "生活"]
  },
  {
    "id": 30,
    "text": "从前的日色变得慢，车、马、邮件都慢，一生只够爱一个人。",
    "source": "《从前慢》",
    "author": "木心",
    "theme": "life-wisdom",
    "tags": ["慢生活", "深情", "怀旧"]
  },
  {
    "id": 31,
    "text": "生活的最佳状态是冷冷清清的风风火火。",
    "source": "《素履之往》",
    "author": "木心",
    "theme": "life-wisdom",
    "tags": ["状态", "冷热", "平衡"]
  },
  {
    "id": 32,
    "text": "我好久没有以小步紧跑去迎接一个人的那种快乐了。",
    "source": "《琼美卡随想录》",
    "author": "木心",
    "theme": "life-wisdom",
    "tags": ["快乐", "期待", "纯真"]
  },
  {
    "id": 33,
    "text": "我们曾如此渴望命运的波澜，到最后才发现：人生最曼妙的风景，竟是内心的淡定与从容。",
    "source": "《一百岁感言》",
    "author": "杨绛",
    "theme": "life-wisdom",
    "tags": ["淡定", "从容", "人生"]
  },
  {
    "id": 34,
    "text": "人间不会有单纯的快乐，快乐总夹杂着烦恼和忧虑。",
    "source": "《我们仨》",
    "author": "杨绛",
    "theme": "life-wisdom",
    "tags": ["快乐", "烦恼", "真实"]
  },
  {
    "id": 35,
    "text": "一个人经过不同程度的锻炼，就获得不同程度的修养、不同程度的效益。",
    "source": "《走到人生边上》",
    "author": "杨绛",
    "theme": "life-wisdom",
    "tags": ["修养", "锻炼", "成长"]
  },
  {
    "id": 36,
    "text": "人生的意义就在于吃吃喝喝，以兴趣为工作，以生活为重心。",
    "source": "《人间好玩》",
    "author": "蔡澜",
    "theme": "life-wisdom",
    "tags": ["乐趣", "吃喝", "兴趣"]
  },
  {
    "id": 37,
    "text": "一切烦恼，都是由贪心开始。要经常学习减少自己的欲望。",
    "source": "《人间好玩》",
    "author": "蔡澜",
    "theme": "life-wisdom",
    "tags": ["贪心", "欲望", "减法"]
  },
  {
    "id": 38,
    "text": "不着急，不害怕，不要脸。",
    "source": "《成事》",
    "author": "冯唐",
    "theme": "life-wisdom",
    "tags": ["成事", "心态", "豁达"]
  },
  {
    "id": 39,
    "text": "天下第一件好事还是读书。",
    "source": "《成事》",
    "author": "冯唐",
    "theme": "life-wisdom",
    "tags": ["读书", "好学", "佳事"]
  },
  {
    "id": 40,
    "text": "做人要通达，通达的人做事做得开，心里不拧巴。",
    "source": "《成事》",
    "author": "冯唐",
    "theme": "life-wisdom",
    "tags": ["通达", "做人", "通透"]
  }
]
